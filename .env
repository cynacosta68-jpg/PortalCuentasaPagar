# Base de datos
DATABASE_URL=postgres://portal:CAMBIAR@portal-db:5432/cuentas_pagar
DB_PASSWORD=CAMBIAR

# Puerto del servidor
PORT=3000

# Seguridad
SESSION_SECRET=    # openssl rand -hex 32
PORTAL_ADMIN_PASS= # contraseña del admin del portal

# Arcanum (gateway ARCA — debe estar corriendo)
ARCANUM_URL=http://arcanum:8094
ARCANUM_API_KEY=   # la misma que configuraste en Arcanum

# Email (para órdenes de pago y aprobaciones de gerencia)
# Si no se configura SMTP_HOST, los mails se envían a Ethereal (solo para pruebas locales)
SMTP_HOST=smtp.tuproveedor.com
SMTP_PORT=587
SMTP_SECURE=false              # true si usás SSL/TLS puerto 465
SMTP_USER=tucuenta@empresa.com
SMTP_PASS=
SMTP_FROM=pagos@empresa.com    # dirección que aparece como remitente

# Datos de la empresa (se imprimen en PDFs de órdenes de pago y certificados)
EMPRESA_NOMBRE=Mi Empresa S.A.
EMPRESA_CUIT=30000000000
EMPRESA_DOMICILIO=Av. Ejemplo 1234, Ciudad Autónoma de Buenos Aires

# Mail interno que recibe copia cuando se ejecuta una corrida
EMAIL_INTERNO=contabilidad@empresa.com

# URL pública del portal (usada en el link de aprobación que se envía a gerencia)
BASE_URL=https://portal.miempresa.com
